      <devhub:change type="feature">Zoom &amp; pan in Graph Mode</devhub:change>
    </devhub:release>
    <devhub:release version="0.0.7" date="2026-06-20">
      <devhub:change type="feature">YAML support via <devhub:code>js-yaml</devhub:code></devhub:change>
      <devhub:change type="feature">XML support via browser <devhub:code>DOMParser</devhub:code></devhub:change>
      <devhub:change type="improvement">Enhanced graph node display</devhub:change>
    </devhub:release>
    <devhub:release version="0.0.6" date="2026-06-10">
      <devhub:change type="feature">PDF export via browser print dialog</devhub:change>
    </devhub:release>
    <devhub:release version="0.0.5" date="2026-05-28">
      <devhub:change type="feature">Mermaid diagram live preview with dark/light theme</devhub:change>
    </devhub:release>
  </devhub:changelog>

