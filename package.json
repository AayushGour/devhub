{
  "name": "devhub-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "web",
    "extension"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @devhub/web",
    "build:web": "npm run build -w @devhub/web",
    "lint:web": "npm run lint -w @devhub/web",
    "build:webview": "npm run build:webview -w devhub-toolkit",
    "build:host": "npm run build:host -w devhub-toolkit",
    "build:ext": "npm run build -w devhub-toolkit",
    "package:ext": "npm run package -w devhub-toolkit",
    "publish:openvsx": "npm run publish:openvsx -w devhub-toolkit",
    "publish:vsce": "npm run publish:vsce -w devhub-toolkit",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
