{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DevHub Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/extension"],
      "outFiles": ["${workspaceFolder}/extension/dist/**/*.cjs"],
      "preLaunchTask": "devhub: build extension"
    }
  ]
}
